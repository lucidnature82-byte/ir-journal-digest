# Google Gemini API key (required)
# Get one at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# NCBI API key (optional — raises rate limit from 3 to 10 req/sec)
# Get one at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Gemini model override (optional — config.py의 GEMINI_MODEL보다 우선 적용)
# 아래 중 하나를 주석 해제하여 사용:
# GEMINI_MODEL=gemini-1.5-flash       # 1500회/일 (권장, 기본값)
# GEMINI_MODEL=gemini-1.5-flash-8b   # 1500회/일 (더 가벼움)
# GEMINI_MODEL=gemini-2.5-flash      # 20회/일 (프리뷰 제한, 비권장)
